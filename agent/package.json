{
  "name": "vara-content-agent",
  "version": "0.1.0",
  "description": "AI x Crypto News Agent — publishes gated content on Vara Network",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:dry": "DRY_RUN=true tsx src/index.ts",
    "run-once": "RUN_ONCE=true tsx src/index.ts",
    "run-once:now": "RUN_ONCE=true RUN_NOW=true tsx src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@gear-js/api": "^0.45.0",
    "@pinata/sdk": "^2.1.0",
    "node-cron": "^3.0.3",
    "sails-js": "^1.0.0",
    "sails-js-parser": "^0.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
